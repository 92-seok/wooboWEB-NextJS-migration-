{
  "compilerOptions": {
    "target": "es5",
    "module": "esnext",
    "moduleResolution": "node",
    // Base Path
    "baseUrl": "./src",
    // Path Alias
    "paths": {
      "@/*": ["*"]
    },
    "lib": ["esnext", "dom", "dom.iterable", "scripthost"]
  },
  // 소스코드가 아닌 파일
  "exclude": ["/node_modules", "/dist", "/.*/"]
}
