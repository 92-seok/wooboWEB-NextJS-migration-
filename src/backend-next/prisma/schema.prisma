// Woobo Online - Portfolio Backend (Anonymized)
// Database: PostgreSQL (Vercel Postgres / Supabase)
// Phase 3: Prisma Schema with Anonymized Tables & Columns

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Auth Models ====================

model User {
  id            Int       @id @default(autoincrement())
  username      String    @unique @db.VarChar(50)
  password      String    @db.VarChar(255)
  email         String    @db.VarChar(100)
  name          String    @db.VarChar(50)
  phone         String?   @db.VarChar(50)
  role          UserRole  @default(OPERATOR)
  is_active     Boolean   @default(true)
  kakao_id      String?   @db.VarChar(100)
  last_login_at DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  authorities UserAuthority[]
  token       UserToken?

  @@map("users")
}

model UserAuthority {
  id        Int    @id @default(autoincrement())
  user_id   Int
  authority String @db.VarChar(255)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_authorities")
}

model UserToken {
  user_id       Int       @id
  hashed_token  String?   @db.VarChar(255)
  last_login_at DateTime?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_tokens")
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

// ==================== Region Models ====================

model Region {
  code        String    @id @db.VarChar(10)
  name        String    @db.VarChar(100)
  admin_name  String    @db.VarChar(100)
  manager     String?   @db.VarChar(100)
  department  String?   @db.VarChar(100)
  contact     String?   @db.VarChar(50)
  memo        String?   @db.VarChar(1000)
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  devices Device[]

  @@index([is_active])
  @@map("regions")
}

// ==================== Device Models ====================

model Device {
  id               String    @id @default(uuid())
  region_code      String    @db.VarChar(10)
  device_code      String    @db.VarChar(10)
  area_code        String?   @db.VarChar(10)
  device_name      String    @db.VarChar(100)
  device_type      DeviceType
  protocol         String?   @db.VarChar(20)
  phone            String?   @db.VarChar(50)
  ip_address       String?   @db.VarChar(50)
  port             String?   @db.VarChar(10)
  last_status      String?   @db.VarChar(20)
  last_updated_at  String?   @db.VarChar(50)
  error_count      Int       @default(5)
  is_active        Boolean   @default(true)
  latitude         Float?
  longitude        Float?
  address          String?   @db.VarChar(200)
  data             String?   @db.Text
  unit             String?   @db.VarChar(20)
  comment          String?   @db.VarChar(500)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  region Region @relation(fields: [region_code], references: [code])

  broadcast_logs BroadcastLog[]
  display_logs   DisplayLog[]
  gate_logs      GateLog[]

  @@unique([region_code, device_code])
  @@index([device_type])
  @@index([region_code])
  @@index([error_count])
  @@map("devices")
}

enum DeviceType {
  RAIN_GAUGE      // 01 - 강우량계
  WATER_LEVEL     // 02 - 수위계
  DISPLACEMENT    // 03 - 변위계
  SNOW_GAUGE      // 06 - 적설계
  WARNING_SYSTEM  // 17 - 예경보
  DISPLAY_BOARD   // 18 - 전광판
  GATE_CONTROL    // 20 - 차단기
  OTHER           // 기타
}

// ==================== Control Log Models ====================

model BroadcastLog {
  id            Int       @id @default(autoincrement())
  device_id     String
  command       String    @db.VarChar(10)
  param1        String?   @db.VarChar(50)
  param2        String?   @db.VarChar(50)
  param3        String?   @db.VarChar(500)
  param4        String?   @db.VarChar(50)
  status        ControlStatus @default(START)
  response_data String?   @db.VarChar(200)
  response_at   DateTime?
  user          String?   @db.VarChar(50)
  registered_at String?   @db.VarChar(50)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  device Device @relation(fields: [device_id], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([created_at])
  @@map("broadcast_logs")
}

model DisplayLog {
  id            Int       @id @default(autoincrement())
  device_id     String
  command       String    @db.VarChar(10)
  param1        String?   @db.VarChar(50)
  param2        String?   @db.VarChar(50)
  param3        String?   @db.VarChar(500)
  status        ControlStatus @default(START)
  user          String?   @db.VarChar(50)
  registered_at String?   @db.VarChar(50)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  device Device @relation(fields: [device_id], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([created_at])
  @@map("display_logs")
}

model GateLog {
  id            Int       @id @default(autoincrement())
  device_id     String
  gate_action   String?   @db.VarChar(20)
  light_action  String?   @db.VarChar(20)
  sound_action  String?   @db.VarChar(20)
  status        ControlStatus @default(START)
  user          String?   @db.VarChar(50)
  registered_at String?   @db.VarChar(50)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  device Device @relation(fields: [device_id], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([created_at])
  @@map("gate_logs")
}

enum ControlStatus {
  START
  ING
  END
  FAIL
  ERROR
}

